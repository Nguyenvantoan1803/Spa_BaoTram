# ============================================================
# SAO CHEP THANH .env va dien gia tri THAT cua ban
# KHONG COMMIT file .env len Git (.gitignore da chan)
# ============================================================

# ---------- DATABASE ----------
# Chuoi ket noi MongoDB Atlas: Atlas > Cluster > Connect > Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.xxxxx.mongodb.net/spabaotram?retryWrites=true&w=majority

# ---------- SERVER ----------
PORT=5000
NODE_ENV=development

# Bat HTTPS redirect (chi bat khi deploy production sau Nginx/Caddy/Cloudflare)
# FORCE_HTTPS=true

# Trust proxy (so hop proxy phia truoc):
# - 0 = khong tin (local)
# - 1 = tin 1 proxy (vd Cloudflare hoac Nginx)
TRUST_PROXY=0

# ---------- CORS (BAT BUOC khi deploy production) ----------
# Domain frontend duoc phep goi API. Phan tach bang dau phay.
# VD: https://spabaotram.com,https://www.spabaotram.com
# De TRONG hoac khong khai bao = CHI cho phep cung domain (an toan)
CLIENT_ORIGIN=http://localhost:3000

# ---------- ADMIN AUTHENTICATION ----------
# Tai khoan dang nhap trang /admin
ADMIN_USERNAME=admin

# Mat khau dang dang BCRYPT HASH (KHONG luu plain text)
# Tao hash bang lenh:
#   node -e "console.log(require('bcryptjs').hashSync('MAT_KHAU_CUA_BAN', 10))"
# Roi paste vao day:
ADMIN_PASSWORD_HASH=$2a$10$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JWT secret - chuoi ngau nhien DAI (it nhat 64 ky tu)
# Tao bang lenh:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=hay-thay-bang-chuoi-ngau-nhien-rat-dai-it-nhat-64-ky-tu-de-an-toan

# Thoi gian JWT (mac dinh 1 ngay - giam tu 7 ngay xuong cho an toan)
JWT_EXPIRES_IN=1d

# ---------- EMAIL (Gmail SMTP) ----------
# SMTP_PASS la App Password 16 ky tu (KHONG phai mat khau Gmail thuong)
# Tao tai: https://myaccount.google.com/apppasswords
SMTP_USER=email-cua-ban@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
OWNER_EMAIL=email-nhan-thong-bao@gmail.com

# ---------- LOGGING ----------
LOG_LEVEL=info

# ---------- SENTRY (tuy chon - error tracking) ----------
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
